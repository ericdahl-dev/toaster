<% content_for :fullpage do %>
<div class="login-page">
  <%= render "shared/theme_toggle", floating: true %>
  <div class="login-box">
    <div class="login-logo">
      <div class="login-logo-icon"><%= render "shared/toast_icon" %></div>
      <span class="login-logo-text">Toaster</span>
    </div>
    <p class="login-eyebrow">Operator sign in</p>

    <% if flash[:alert].present? %>
      <div class="flash flash-alert" style="position:static;margin-bottom:20px;animation:none"><%= flash[:alert] %></div>
    <% end %>

    <%= form_with url: login_path, method: :post do |f| %>
      <div class="form-group">
        <%= f.label :email, "Email", class: "form-label" %>
        <%= f.email_field "user[email]", required: true, autofocus: true, class: "form-input", placeholder: "you@venue.com" %>
      </div>
      <div class="form-group">
        <%= f.label :password, "Password", class: "form-label" %>
        <%= f.password_field "user[password]", required: true, class: "form-input", placeholder: "••••••••" %>
      </div>
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
        <%= check_box_tag "user[remember_me]", "1", false, style: "width:14px;height:14px;accent-color:var(--amber);cursor:pointer", id: "user_remember_me" %>
        <%= label_tag "user_remember_me", "Remember me", style: "font-size:12px;color:var(--muted);cursor:pointer;margin:0" %>
      </div>
      <div style="margin-top:24px">
        <%= f.submit "Sign in →", class: "btn btn-amber", style: "width:100%;justify-content:center;padding:10px 0;font-size:12px" %>
      </div>
    <% end %>

    <div style="margin-top:20px;text-align:center">
      <%= link_to "Forgot password?", new_user_password_path, class: "auth-link" %>
    </div>
  </div>
</div>
<% end %>
