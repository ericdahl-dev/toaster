<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Toaster" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if content_for?(:fullpage) %>
      <%= yield :fullpage %>
    <% else %>
      <div class="shell <%= 'shell--no-sidebar' unless current_user %>" data-controller="mobile-nav">
        <header class="topbar">
          <% if current_user %>
            <button class="nav-toggle" data-action="mobile-nav#toggle" aria-label="Toggle navigation">
              <span class="nav-toggle-bar"></span>
              <span class="nav-toggle-bar"></span>
              <span class="nav-toggle-bar"></span>
            </button>
          <% end %>
          <a href="/" class="topbar-logo">
            <div class="toast-icon">🍞</div>
            Toaster
          </a>
          <div class="topbar-sep"></div>
          <% if current_user %>
            <div class="topbar-user">
              <span class="topbar-email"><%= current_user.email %></span>
              <%= button_to "sign out", logout_path, method: :delete, class: "btn btn-ghost", style: "padding: 3px 9px; font-size: 11px;" %>
            </div>
          <% end %>
        </header>

        <% if current_user %>
          <div class="sidebar-overlay" data-action="click->mobile-nav#close" data-mobile-nav-target="overlay"></div>

          <nav class="sidebar sidebar-drawer" data-mobile-nav-target="drawer">
            <div class="sidebar-close-row">
              <button class="sidebar-close-btn" data-action="mobile-nav#close" aria-label="Close navigation">✕</button>
            </div>
            <div class="sidebar-section">Operations</div>
            <%= link_to booking_requests_path, class: "nav-link #{request.path.start_with?('/booking_requests') ? 'active' : ''}", data: {action: "mobile-nav#close"} do %>
              <span class="icon">📋</span> Requests
            <% end %>
            <%= link_to mail_connections_path, class: "nav-link #{request.path.start_with?('/mail_connections') ? 'active' : ''}", data: {action: "mobile-nav#close"} do %>
              <span class="icon">📬</span> Mail
            <% end %>
            <%= link_to venues_path, class: "nav-link #{request.path.start_with?('/venues') ? 'active' : ''}", data: {action: "mobile-nav#close"} do %>
              <span class="icon">🏛️</span> Venues
            <% end %>
            <%= link_to inbox_threads_path, class: "nav-link #{request.path.start_with?('/inbox_threads') ? 'active' : ''}", data: {action: "mobile-nav#close"} do %>
              <span class="icon">💬</span> Threads
            <% end %>
            <div class="sidebar-section" style="margin-top:8px">System</div>
            <%= link_to "/jobs", class: "nav-link", data: {action: "mobile-nav#close"} do %>
              <span class="icon">⚙️</span> Jobs
            <% end %>
            <%= link_to "/ops", class: "nav-link #{request.path.start_with?('/ops') ? 'active' : ''}", data: {action: "mobile-nav#close"} do %>
              <span class="icon">🔭</span> Ops
            <% end %>
          </nav>
        <% end %>

        <main class="main">
          <% if notice.present? %>
            <div class="flash flash-notice"><%= notice %></div>
          <% end %>
          <% if alert.present? %>
            <div class="flash flash-alert"><%= alert %></div>
          <% end %>
          <%= yield %>
        </main>
      </div>
    <% end %>
  </body>
</html>
