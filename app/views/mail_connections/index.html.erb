<div class="page-header">
  <div>
    <h1 class="page-title">Mail Connections</h1>
    <p class="page-subtitle">IMAP inboxes synced for booking requests</p>
  </div>
  <%= link_to "+ Add connection", new_mail_connection_path, class: "btn btn-ghost" %>
</div>

<% if @imap_connections.empty? %>
  <div class="card">
    <div class="empty-state">
      <div class="empty-icon">📬</div>
      <span>No mail connections configured</span>
      <span class="dim" style="font-size:11px">Add an IMAP connection to start receiving booking requests</span>
      <%= link_to "+ Add connection", new_mail_connection_path, class: "btn btn-amber", style: "margin-top:4px" %>
    </div>
  </div>
<% else %>
  <div class="card">
    <table class="data-table">
      <thead>
        <tr>
          <th>Account</th>
          <th>Host</th>
          <th>Folder</th>
          <th>Status</th>
          <th>Last synced</th>
        </tr>
      </thead>
      <tbody>
        <% @imap_connections.each do |conn| %>
          <tr>
            <td><span class="hi"><%= conn.username %></span></td>
            <td class="dim"><%= conn.host %>:<%= conn.port %></td>
            <td class="dim"><%= conn.inbox_folder %></td>
            <td>
              <span class="badge <%= conn.active? ? 'badge-active' : 'badge-inactive' %>">
                <%= conn.active? ? "active" : "inactive" %>
              </span>
            </td>
            <td class="dim">—</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
