<div class="max-w-lg mx-auto px-4 py-8">
  <%= link_to "← Mail connections", mail_connections_path, class: "text-sm text-slate-500 hover:text-slate-900" %>

  <h1 class="text-xl font-semibold text-slate-900 mt-6 mb-6">Add Mail Connection</h1>

  <% if flash[:alert].present? %>
    <div class="mb-4 rounded-md bg-red-50 px-4 py-3 text-sm text-red-700"><%= flash[:alert] %></div>
  <% end %>

  <% if defined?(@connection) && @connection&.errors&.any? %>
    <div class="mb-4 rounded-md bg-red-50 px-4 py-3 text-sm text-red-700">
      <ul class="list-disc list-inside space-y-1">
        <% @connection.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: mail_connections_path, method: :post do |f| %>
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-slate-700">Connection type</label>
        <select name="mail_connection[type]" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
          <option value="imap">IMAP</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Host</label>
        <input type="text" name="mail_connection[host]" value="<%= @connection&.host %>"
          class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Port</label>
        <input type="number" name="mail_connection[port]" value="<%= @connection&.port || 993 %>"
          class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Username (email)</label>
        <input type="email" name="mail_connection[username]" value="<%= @connection&.username %>"
          class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Password</label>
        <input type="password" name="mail_connection[password]"
          class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Inbox folder</label>
        <input type="text" name="mail_connection[inbox_folder]" value="<%= @connection&.inbox_folder || 'INBOX' %>"
          class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
      </div>
      <div class="pt-2">
        <button type="submit" class="w-full rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700">
          Add connection
        </button>
      </div>
    </div>
  <% end %>
</div>
