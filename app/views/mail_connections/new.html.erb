<%= link_to "← Mail connections", mail_connections_path, class: "back-link" %>

<div class="page-header">
  <h1 class="page-title">Add Mail Connection</h1>
</div>

<% if flash[:alert].present? %>
  <div class="flash flash-alert" style="position:static;margin-bottom:20px;animation:none"><%= flash[:alert] %></div>
<% end %>

<% if defined?(@connection) && @connection&.errors&.any? %>
  <div class="flash flash-alert" style="position:static;margin-bottom:20px;animation:none">
    <% @connection.errors.full_messages.each do |msg| %>
      <div><%= msg %></div>
    <% end %>
  </div>
<% end %>

<div style="max-width:480px">
  <%= form_with url: mail_connections_path, method: :post do |f| %>
    <div class="form-group">
      <label class="form-label">Connection type</label>
      <select name="mail_connection[type]" class="form-select">
        <option value="imap">IMAP</option>
      </select>
    </div>
    <div class="form-group">
      <label class="form-label">Host</label>
      <input type="text" name="mail_connection[host]" value="<%= @connection&.host %>"
        placeholder="imap.gmail.com" class="form-input">
    </div>
    <div class="form-group">
      <label class="form-label">Port</label>
      <input type="number" name="mail_connection[port]" value="<%= @connection&.port || 993 %>"
        class="form-input">
    </div>
    <div class="form-group">
      <label class="form-label">Username (email)</label>
      <input type="email" name="mail_connection[username]" value="<%= @connection&.username %>"
        placeholder="bookings@venue.com" class="form-input">
    </div>
    <div class="form-group">
      <label class="form-label">Password</label>
      <input type="password" name="mail_connection[password]" class="form-input">
    </div>
    <div class="form-group">
      <label class="form-label">Inbox folder</label>
      <input type="text" name="mail_connection[inbox_folder]" value="<%= @connection&.inbox_folder || 'INBOX' %>"
        class="form-input">
    </div>
    <div style="margin-top:24px;display:flex;gap:10px">
      <button type="submit" class="btn btn-amber">Add connection</button>
      <%= link_to "Cancel", mail_connections_path, class: "btn btn-ghost" %>
    </div>
  <% end %>
</div>
