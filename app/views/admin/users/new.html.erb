<div class="page-header">
  <h1 class="page-title">Add User to Account</h1>
  <p class="page-subtitle">Add a venue manager to an existing account.</p>
</div>

<% if @user.errors.any? %>
  <div class="flash flash-alert" style="position:static;margin-bottom:20px;animation:none">
    <% @user.errors.full_messages.each do |msg| %>
      <div><%= msg %></div>
    <% end %>
  </div>
<% end %>

<div style="max-width:480px">
  <%= form_with url: admin_users_path, method: :post do |f| %>
    <div class="form-group">
      <label class="form-label">Account</label>
      <%= select_tag "user[account_id]", options_from_collection_for_select(@accounts, :id, :name, @user.account_id), class: "form-input", prompt: "Select account" %>
    </div>
    <div class="form-group">
      <label class="form-label">Name</label>
      <%= text_field_tag "user[name]", @user.name, class: "form-input", placeholder: "Jane Smith" %>
    </div>
    <div class="form-group">
      <label class="form-label">Email</label>
      <%= email_field_tag "user[email]", @user.email, class: "form-input", placeholder: "jane@example.com" %>
    </div>
    <div class="form-group">
      <label class="form-label">Temporary password</label>
      <%= password_field_tag "user[password]", nil, class: "form-input", autocomplete: "new-password" %>
    </div>
    <div style="display:flex;gap:10px;margin-top:24px">
      <button type="submit" class="btn btn-amber">Add user</button>
    </div>
  <% end %>
</div>
