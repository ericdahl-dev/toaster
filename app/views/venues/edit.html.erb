<%= link_to "← Venues", venues_path, class: "back-link" %>

<div class="page-header">
  <h1 class="page-title">Edit Venue</h1>
</div>

<% if @venue.errors.any? %>
  <div class="flash flash-alert" style="position:static;margin-bottom:20px;animation:none">
    <% @venue.errors.full_messages.each do |msg| %>
      <div><%= msg %></div>
    <% end %>
  </div>
<% end %>

<div style="max-width:600px">
  <%= form_with model: @venue, url: venue_path(@venue), method: :patch do |f| %>

    <%# Venue fields %>
    <div class="form-group">
      <label class="form-label">Name</label>
      <%= f.text_field :name, class: "form-input" %>
    </div>
    <div class="form-group">
      <label class="form-label">Address</label>
      <%= f.text_field :address, class: "form-input", placeholder: "123 Main St, Chicago, IL" %>
    </div>
    <div class="form-group">
      <label class="form-label">Capacity (reception-style)</label>
      <%= f.number_field :capacity, class: "form-input", placeholder: "150", min: 1 %>
    </div>
    <div class="form-group">
      <label class="form-label">Venue amenities</label>
      <%= f.text_field :features, class: "form-input",
            value: @venue.features.join(", "),
            placeholder: "karaoke, coat check, parking" %>
      <p style="font-size:11px;color:#6b7280;margin-top:4px">Venue-wide amenities available across all spaces.</p>
    </div>

    <%# Spaces %>
    <div style="margin-top:32px;margin-bottom:8px">
      <span class="page-subtitle" style="font-size:13px;font-weight:600;color:#f0f2f2">Spaces</span>
    </div>

    <div data-controller="nested-form">
      <div data-nested-form-target="container">
        <% @venue.venue_spaces.each do |space| %>
          <%= f.fields_for :venue_spaces, space do |sf| %>
            <div data-nested-form-target="row" style="border:1px solid #252626;border-radius:6px;padding:14px;margin-bottom:10px;position:relative">
              <%= sf.hidden_field :id %>
              <%= sf.hidden_field :_destroy, value: "0" %>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px">
                <div class="form-group" style="margin:0">
                  <label class="form-label">Space name</label>
                  <%= sf.text_field :name, class: "form-input", placeholder: "Rooftop" %>
                </div>
                <div class="form-group" style="margin:0">
                  <label class="form-label">Min guests</label>
                  <%= sf.number_field :min_guests, class: "form-input", placeholder: "—", min: 1 %>
                </div>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:10px">
                <div class="form-group" style="margin:0">
                  <label class="form-label">Max guests</label>
                  <%= sf.number_field :max_guests, class: "form-input", placeholder: "—", min: 1 %>
                </div>
                <div class="form-group" style="margin:0">
                  <label class="form-label">Capacity (seated)</label>
                  <%= sf.number_field :capacity_seated, class: "form-input", placeholder: "—", min: 1 %>
                </div>
                <div class="form-group" style="margin:0">
                  <label class="form-label">Capacity (reception)</label>
                  <%= sf.number_field :capacity_reception, class: "form-input", placeholder: "—", min: 1 %>
                </div>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px">
                <div class="form-group" style="margin:0">
                  <label class="form-label">Pricing floor (¢)</label>
                  <%= sf.number_field :pricing_floor_cents, class: "form-input", placeholder: "—", min: 0 %>
                </div>
                <div class="form-group" style="margin:0;display:flex;align-items:center;gap:8px;padding-top:20px">
                  <%= sf.check_box :private %>
                  <label class="form-label" style="margin:0">Private space</label>
                </div>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                <div class="form-group" style="margin:0">
                  <label class="form-label">Duration options</label>
                  <%= sf.text_field :duration_options, class: "form-input",
                        value: space.duration_options.join(", "),
                        placeholder: "2_hours, 2_5_hours, all_night" %>
                </div>
                <div class="form-group" style="margin:0">
                  <label class="form-label">Space amenities</label>
                  <%= sf.text_field :features, class: "form-input",
                        value: space.features.join(", "),
                        placeholder: "private_bar, stage" %>
                </div>
              </div>
              <button type="button" style="position:absolute;top:10px;right:10px;background:none;border:none;color:#6b7280;cursor:pointer;font-size:13px"
                      data-action="nested-form#removeRow">Remove</button>
            </div>
          <% end %>
        <% end %>
      </div>

      <%# Template for new rows %>
      <template data-nested-form-target="template">
        <%= f.fields_for :venue_spaces, VenueSpace.new, child_index: "NEW_RECORD" do |sf| %>
          <div data-nested-form-target="row" style="border:1px solid #252626;border-radius:6px;padding:14px;margin-bottom:10px;position:relative">
            <%= sf.hidden_field :_destroy, value: "0" %>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px">
              <div class="form-group" style="margin:0">
                <label class="form-label">Space name</label>
                <%= sf.text_field :name, class: "form-input", placeholder: "Rooftop" %>
              </div>
              <div class="form-group" style="margin:0">
                <label class="form-label">Min guests</label>
                <%= sf.number_field :min_guests, class: "form-input", placeholder: "—", min: 1 %>
              </div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:10px">
              <div class="form-group" style="margin:0">
                <label class="form-label">Max guests</label>
                <%= sf.number_field :max_guests, class: "form-input", placeholder: "—", min: 1 %>
              </div>
              <div class="form-group" style="margin:0">
                <label class="form-label">Capacity (seated)</label>
                <%= sf.number_field :capacity_seated, class: "form-input", placeholder: "—", min: 1 %>
              </div>
              <div class="form-group" style="margin:0">
                <label class="form-label">Capacity (reception)</label>
                <%= sf.number_field :capacity_reception, class: "form-input", placeholder: "—", min: 1 %>
              </div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px">
              <div class="form-group" style="margin:0">
                <label class="form-label">Pricing floor (¢)</label>
                <%= sf.number_field :pricing_floor_cents, class: "form-input", placeholder: "—", min: 0 %>
              </div>
              <div class="form-group" style="margin:0;display:flex;align-items:center;gap:8px;padding-top:20px">
                <%= sf.check_box :private %>
                <label class="form-label" style="margin:0">Private space</label>
              </div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
              <div class="form-group" style="margin:0">
                <label class="form-label">Duration options</label>
                <%= sf.text_field :duration_options, class: "form-input", placeholder: "2_hours, 2_5_hours, all_night" %>
              </div>
              <div class="form-group" style="margin:0">
                <label class="form-label">Space amenities</label>
                <%= sf.text_field :features, class: "form-input", placeholder: "private_bar, stage" %>
              </div>
            </div>
            <button type="button" style="position:absolute;top:10px;right:10px;background:none;border:none;color:#6b7280;cursor:pointer;font-size:13px"
                    data-action="nested-form#removeRow">Remove</button>
          </div>
        <% end %>
      </template>

      <button type="button" class="btn btn-ghost" style="font-size:12px;margin-top:4px"
              data-action="nested-form#addRow">+ Add space</button>
    </div>

    <div style="margin-top:28px;display:flex;gap:10px">
      <button type="submit" class="btn btn-amber">Save changes</button>
      <%= link_to "Cancel", venues_path, class: "btn btn-ghost" %>
    </div>

  <% end %>
</div>

<%# Knowledge documents — separate form, outside venue form %>
<div style="max-width:600px;margin-top:40px">
  <div style="margin-bottom:12px">
    <span class="page-subtitle" style="font-size:13px;font-weight:600;color:#f0f2f2">Knowledge Documents</span>
    <p style="font-size:12px;color:#6b7280;margin-top:4px">Upload PDFs or text files describing your venue. The AI will use these to answer booking inquiries.</p>
  </div>

  <%= form_with url: venue_documents_path(@venue), method: :post, multipart: true do |f| %>
    <div style="display:flex;gap:10px;align-items:center">
      <%= f.file_field :file, accept: ".pdf,.txt,.docx", class: "form-input", style: "flex:1;font-size:12px;padding:8px" %>
      <button type="submit" class="btn btn-amber" style="white-space:nowrap">Upload</button>
    </div>
  <% end %>

  <% if @venue.venue_documents.any? %>
    <div style="margin-top:16px;display:flex;flex-direction:column;gap:8px">
      <% @venue.venue_documents.order(created_at: :desc).each do |doc| %>
        <%
          status_color = case doc.status
          when "ready"       then "#16a34a"
          when "processing"  then "#d97706"
          when "failed"      then "#dc2626"
          else "#6b7280"
          end
        %>
        <div style="display:flex;align-items:center;justify-content:space-between;border:1px solid #252626;border-radius:6px;padding:10px 14px">
          <div style="flex:1;min-width:0">
            <div style="font-size:13px;color:#f0f2f2;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= doc.source_filename %></div>
            <div style="display:flex;align-items:center;gap:8px;margin-top:4px">
              <span style="font-size:11px;font-weight:600;color:<%= status_color %>"><%= doc.status.upcase %></span>
              <% if doc.ready? %>
                <span style="font-size:11px;color:#6b7280"><%= doc.chunk_count %> chunks</span>
              <% end %>
              <% if doc.failed? && doc.error_message.present? %>
                <span style="font-size:11px;color:#dc2626" title="<%= doc.error_message %>">Error: <%= doc.error_message.truncate(60) %></span>
              <% end %>
            </div>
          </div>
          <%= button_to venue_document_path(@venue, doc), method: :delete,
                data: {confirm: "Delete this document and all its chunks?"},
                style: "background:none;border:none;color:#6b7280;cursor:pointer;font-size:12px;padding:4px 8px;white-space:nowrap" do %>
            Delete
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p style="font-size:12px;color:#6b7280;margin-top:12px">No documents uploaded yet.</p>
  <% end %>
</div>
