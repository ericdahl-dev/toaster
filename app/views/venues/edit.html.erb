<%= link_to "← Venues", venues_path, class: "back-link" %>

<div class="page-header">
  <h1 class="page-title">Edit Venue</h1>
</div>

<% if @venue.errors.any? %>
  <div class="flash flash-alert" style="position:static;margin-bottom:20px;animation:none">
    <% @venue.errors.full_messages.each do |msg| %>
      <div><%= msg %></div>
    <% end %>
  </div>
<% end %>

<div style="max-width:480px">
  <%= form_with model: @venue, url: venue_path(@venue), method: :patch do |f| %>
    <div class="form-group">
      <label class="form-label">Name</label>
      <%= f.text_field :name, class: "form-input" %>
    </div>
    <div style="margin-top:24px;display:flex;gap:10px">
      <button type="submit" class="btn btn-amber">Save changes</button>
      <%= link_to "Cancel", venues_path, class: "btn btn-ghost" %>
    </div>
  <% end %>
</div>
