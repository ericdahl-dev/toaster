<%= link_to "← Venues", venues_path, class: "back-link" %>

<div class="page-header">
  <h1 class="page-title">Add Venue</h1>
</div>

<% if @venue.errors.any? %>
  <div class="flash flash-alert" style="position:static;margin-bottom:20px;animation:none">
    <% @venue.errors.full_messages.each do |msg| %>
      <div><%= msg %></div>
    <% end %>
  </div>
<% end %>

<div style="max-width:480px">
  <%= form_with model: @venue, url: venues_path, method: :post do |f| %>
    <div class="form-group">
      <label class="form-label">Name</label>
      <%= f.text_field :name, class: "form-input", placeholder: "The Grand Hall" %>
    </div>
    <div class="form-group">
      <label class="form-label">Address</label>
      <%= f.text_field :address, class: "form-input", placeholder: "123 Main St, Chicago, IL" %>
    </div>
    <div class="form-group">
      <label class="form-label">Capacity (reception-style)</label>
      <%= f.number_field :capacity, class: "form-input", placeholder: "150", min: 1 %>
    </div>
    <div style="margin-top:24px;display:flex;gap:10px">
      <button type="submit" class="btn btn-amber">Create venue</button>
      <%= link_to "Cancel", venues_path, class: "btn btn-ghost" %>
    </div>
  <% end %>
</div>
