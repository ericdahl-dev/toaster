<% content_for :fullpage do %>
<div class="login-page">
  <div class="login-box">
    <div class="login-logo">
      <div class="login-logo-icon"><%= render "shared/toast_icon" %></div>
      <span class="login-logo-text">Toaster</span>
    </div>

    <div class="onboarding-step-bar">
      <span class="onboarding-step onboarding-step--done"></span>
      <span class="onboarding-step onboarding-step--done"></span>
      <span class="onboarding-step onboarding-step--active"></span>
    </div>

    <p class="login-eyebrow">Step 2 — Connect inbox</p>

    <%= form_with url: mail_connections_path, method: :post do |f| %>
      <div class="form-group">
        <%= f.label :host, "IMAP host", class: "form-label" %>
        <%= f.text_field :host, placeholder: "imap.gmail.com", required: true, class: "form-input", autofocus: true %>
      </div>
      <div class="form-group">
        <%= f.label :port, "Port", class: "form-label" %>
        <%= f.number_field :port, placeholder: "993", value: 993, class: "form-input" %>
      </div>
      <div class="form-group">
        <%= f.label :username, "Email", class: "form-label" %>
        <%= f.email_field :username, placeholder: "you@venue.com", required: true, class: "form-input" %>
      </div>
      <div class="form-group">
        <%= f.label :password, "Password / app password", class: "form-label" %>
        <%= f.password_field :password, placeholder: "••••••••", required: true, class: "form-input" %>
      </div>
      <%= f.hidden_field :onboarding, value: true %>
      <div style="margin-top:24px;display:flex;flex-direction:column;gap:10px">
        <%= f.submit "Connect →", class: "btn btn-amber", style: "width:100%;justify-content:center;padding:10px 0;font-size:12px" %>
        <%= link_to "Skip setup", onboarding_skip_path, class: "auth-link", style: "text-align:center;display:block", data: {turbo_method: :post} %>
      </div>
    <% end %>
  </div>
</div>
<% end %>
