<%= link_to "← All requests", booking_requests_path, class: "back-link" %>

<div class="page-header">
  <div>
    <h1 class="page-title"><%= @booking_request.contact.name %></h1>
    <p class="page-subtitle"><%= @booking_request.contact.email %></p>
  </div>
  <span class="badge badge-<%= @booking_request.status %>"><%= @booking_request.status %></span>
</div>

<div class="detail-grid">
  <% if @booking_request.event_date %>
    <div class="detail-cell">
      <div class="detail-label">Event date</div>
      <div class="detail-value"><%= @booking_request.event_date.strftime("%-d %b %Y") %></div>
    </div>
  <% end %>
  <% if @booking_request.event_end_date %>
    <div class="detail-cell">
      <div class="detail-label">End date</div>
      <div class="detail-value"><%= @booking_request.event_end_date.strftime("%-d %b %Y") %></div>
    </div>
  <% end %>
  <% if @booking_request.headcount %>
    <div class="detail-cell">
      <div class="detail-label">Headcount</div>
      <div class="detail-value"><%= @booking_request.headcount %></div>
    </div>
  <% end %>
  <% if @booking_request.budget_cents %>
    <div class="detail-cell">
      <div class="detail-label">Budget</div>
      <div class="detail-value">$<%= (@booking_request.budget_cents / 100.0).round(0) %></div>
    </div>
  <% end %>
  <% if @booking_request.venue %>
    <div class="detail-cell">
      <div class="detail-label">Venue</div>
      <div class="detail-value"><%= @booking_request.venue.name %></div>
    </div>
  <% end %>
  <div class="detail-cell">
    <div class="detail-label">Received</div>
    <div class="detail-value"><%= @booking_request.created_at.strftime("%-d %b %Y") %></div>
  </div>
</div>

<%
  allowed = BookingRequests::Transition::ALLOWED_TRANSITIONS[@booking_request.status] || []
%>
<% if allowed.any? %>
  <div class="section-heading">Actions</div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <% allowed.each do |target| %>
      <%= button_to target.humanize,
            transition_booking_request_path(@booking_request),
            method: :post,
            params: {to: target},
            class: "btn #{target == 'confirmed' ? 'btn-success' : target == 'rejected' || target == 'cancelled' ? 'btn-danger' : 'btn-ghost'}" %>
    <% end %>
  </div>
<% end %>

<% if @booking_request.drafts.any? %>
  <div class="section-heading">Drafts</div>
  <div style="display:flex;flex-direction:column;gap:12px">
    <% @booking_request.drafts.order(created_at: :desc).each do |draft| %>
      <div class="draft-card">
        <div class="draft-card-header">
          <span class="badge badge-<%= draft.status %>"><%= draft.status.humanize %></span>
          <span class="dim" style="font-size:11px"><%= draft.created_at.strftime("%-d %b %Y %H:%M") %></span>
        </div>
        <div class="draft-card-body"><%= draft.body %></div>
        <% if draft.pending_review? %>
          <div class="draft-card-actions">
            <%= button_to "✓ Approve", approve_booking_request_draft_path(@booking_request, draft), method: :post, class: "btn btn-success" %>
            <%= button_to "✕ Reject",  reject_booking_request_draft_path(@booking_request, draft),  method: :post, class: "btn btn-danger" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<%
  event_logs = EventLog.where(subject_type: "BookingRequest", subject_id: @booking_request.id)
                       .order(created_at: :asc)
%>
<% if event_logs.any? %>
  <div class="section-heading">Event log</div>
  <div class="card">
    <table class="data-table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Event</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody>
        <% event_logs.each do |log| %>
          <tr>
            <td class="dim" style="white-space:nowrap"><%= log.created_at.strftime("%-d %b %Y %H:%M") %></td>
            <td><code style="font-size:11px"><%= log.event_type %></code></td>
            <td class="dim" style="font-size:11px"><%= log.payload.to_json %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
