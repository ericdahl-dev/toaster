<%= link_to "← All requests", booking_requests_path, class: "back-link" %>

<div class="page-header">
  <div>
    <h1 class="page-title"><%= @booking_request.contact.name %></h1>
    <p class="page-subtitle"><%= @booking_request.contact.email %></p>
  </div>
  <span class="badge badge-<%= @booking_request.status %>"><%= @booking_request.status %></span>
</div>

<div class="detail-grid">
  <% if @booking_request.event_date %>
    <div class="detail-cell">
      <div class="detail-label">Event date</div>
      <div class="detail-value"><%= @booking_request.event_date.strftime("%-d %b %Y") %></div>
    </div>
  <% end %>
  <% if @booking_request.event_end_date %>
    <div class="detail-cell">
      <div class="detail-label">End date</div>
      <div class="detail-value"><%= @booking_request.event_end_date.strftime("%-d %b %Y") %></div>
    </div>
  <% end %>
  <% if @booking_request.headcount %>
    <div class="detail-cell">
      <div class="detail-label">Headcount</div>
      <div class="detail-value"><%= @booking_request.headcount %></div>
    </div>
  <% end %>
  <% if @booking_request.budget %>
    <div class="detail-cell">
      <div class="detail-label">Budget</div>
      <div class="detail-value">$<%= @booking_request.budget.to_i %></div>
    </div>
  <% end %>
  <% if @booking_request.venue %>
    <div class="detail-cell">
      <div class="detail-label">Venue</div>
      <div class="detail-value"><%= @booking_request.venue.name %></div>
    </div>
  <% end %>
  <div class="detail-cell">
    <div class="detail-label">Received</div>
    <div class="detail-value"><%= @booking_request.created_at.strftime("%-d %b %Y") %></div>
  </div>
</div>

<%
  allowed = BookingRequests::Transition::ALLOWED_TRANSITIONS[@booking_request.status] || []
%>
<% if allowed.any? %>
  <div class="section-heading" style="margin-top:28px">Actions</div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;padding:16px;background:var(--surface);border:1px solid var(--border);border-radius:6px">
    <% allowed.each do |target| %>
      <%
        btn_class = case target
          when "confirmed" then "btn-success"
          when "cancelled" then "btn-danger"
          else "btn-ghost"
        end
      %>
      <%= button_to target.humanize,
            transition_booking_request_path(@booking_request),
            method: :post,
            params: {to: target},
            class: "btn #{btn_class}",
            data: {"turbo-confirm": target == "cancelled" ? "Mark as #{target}?" : nil}.compact %>
    <% end %>
  </div>
<% end %>

<%
  # Build a unified chronological thread from messages + sent/approved/modified drafts + pending drafts
  thread_items = []

  # Source inbox message as the first inbound item (if not already in messages)
  if (src = @booking_request.source_inbox_message)
    thread_items << {
      type: :inbound_email,
      timestamp: src.received_at || @booking_request.created_at,
      subject: src.subject,
      from_name: src.from_name,
      from_email: src.from_email,
      body_html: src.body_html,
      body_text: src.body_text
    }
  end

  # Additional inbound messages (skip source message duplicate)
  source_provider_id = @booking_request.source_inbox_message&.provider_message_id
  @booking_request.messages.where(direction: "inbound").order(sent_at: :asc).each do |msg|
    # Skip if it matches the source inbox message already added
    next if source_provider_id.present? && msg.provider_message_id.present? &&
            msg.provider_message_id.end_with?(source_provider_id.to_s)
    thread_items << {
      type: :inbound_message,
      timestamp: msg.sent_at || msg.created_at,
      body_text: msg.body_text,
      body_html: msg.body_html
    }
  end

  # Sent/approved/modified drafts as outbound items
  @booking_request.drafts.where(status: %w[approved modified sent]).order(created_at: :asc).each do |draft|
    thread_items << {
      type: :outbound_draft,
      timestamp: draft.created_at,
      body: draft.body,
      status: draft.status
    }
  end

  # Pending drafts shown at the end
  pending_drafts = @booking_request.drafts.where(status: "pending_review").order(created_at: :desc)

  thread_items.sort_by! { |item| item[:timestamp] || Time.at(0) }
%>

<% if thread_items.any? || pending_drafts.any? %>
  <div class="section-heading" style="margin-top:28px">Conversation</div>
  <div class="thread-timeline">

    <% thread_items.each do |item| %>
      <% if item[:type] == :inbound_email || item[:type] == :inbound_message %>
        <div class="thread-bubble thread-bubble--inbound">
          <div class="thread-bubble-meta">
            <% if item[:from_name].present? %>
              <span class="thread-sender"><%= item[:from_name] %></span>
              <span class="dim" style="font-size:11px">&lt;<%= item[:from_email] %>&gt;</span>
            <% else %>
              <span class="thread-sender"><%= @booking_request.contact.name %></span>
            <% end %>
            <span class="thread-timestamp dim"><%= item[:timestamp]&.strftime("%-d %b %Y %H:%M") %></span>
          </div>
          <% if item[:subject].present? %>
            <div class="thread-subject dim" style="font-size:11px;margin-bottom:8px">
              Subject: <span style="color:var(--text)"><%= item[:subject] %></span>
            </div>
          <% end %>
          <div class="thread-bubble-body">
            <% if item[:body_html].present? %>
              <iframe srcdoc="<%= h(item[:body_html]) %>" sandbox="" style="width:100%;min-height:120px;border:none;background:#fff;border-radius:3px" title="Email body"></iframe>
            <% else %>
              <pre style="white-space:pre-wrap;font-family:inherit;font-size:13px;color:var(--text);margin:0"><%= item[:body_text] %></pre>
            <% end %>
          </div>
        </div>
      <% elsif item[:type] == :outbound_draft %>
        <div class="thread-bubble thread-bubble--outbound">
          <div class="thread-bubble-meta">
            <span class="thread-sender" style="color:var(--blue)">Venue</span>
            <span class="badge badge-<%= item[:status] %>" style="font-size:10px;padding:1px 6px"><%= item[:status].humanize %></span>
            <span class="thread-timestamp dim"><%= item[:timestamp]&.strftime("%-d %b %Y %H:%M") %></span>
          </div>
          <div class="thread-bubble-body">
            <pre style="white-space:pre-wrap;font-family:inherit;font-size:13px;color:var(--text-hi);margin:0"><%= item[:body] %></pre>
          </div>
        </div>
      <% end %>
    <% end %>

    <% pending_drafts.each do |draft| %>
      <div class="thread-bubble thread-bubble--pending">
        <div class="thread-bubble-meta">
          <span class="thread-sender" style="color:var(--amber)">AI Draft</span>
          <span class="badge badge-pending" style="font-size:10px;padding:1px 6px">Pending review</span>
          <span class="thread-timestamp dim"><%= draft.created_at.strftime("%-d %b %Y %H:%M") %></span>
        </div>
        <div class="thread-bubble-body" style="margin-bottom:12px">
          <pre style="white-space:pre-wrap;font-family:inherit;font-size:13px;color:var(--text-hi);margin:0"><%= draft.body %></pre>
        </div>
        <div class="draft-card-actions">
          <%= button_to "✓ Approve", approve_booking_request_draft_path(@booking_request, draft), method: :post, class: "btn btn-success" %>
          <%= button_to "✕ Reject",  reject_booking_request_draft_path(@booking_request, draft),  method: :post, class: "btn btn-danger" %>
        </div>
      </div>
    <% end %>

  </div>
<% end %>

<% if @booking_request.staff_summary.present? %>
  <div class="section-heading" style="margin-top:28px">AI summary</div>
  <div class="card" style="margin-bottom:24px">
    <p style="margin:0;font-size:14px;color:var(--text)"><%= @booking_request.staff_summary %></p>
  </div>
<% end %>

<% if (ai_runs = @booking_request.ai_runs.order(created_at: :desc)).any? %>
  <div class="section-heading" style="margin-top:28px">AI runs</div>
  <div class="card" style="margin-bottom:24px">
    <div class="table-scroll">
    <table class="data-table">
      <thead>
        <tr><th>Type</th><th>Model</th><th>Version</th><th>Latency</th><th>RAG chunks</th><th>Time</th><th></th></tr>
      </thead>
      <tbody>
        <% ai_runs.each do |run| %>
          <tr>
            <td><code style="font-size:11px"><%= run.run_type %></code></td>
            <td class="dim" style="font-size:12px"><%= run.llm_model %></td>
            <td class="dim" style="font-size:12px"><%= run.prompt_version %></td>
            <td class="dim" style="font-size:12px"><%= run.latency_ms %>ms</td>
            <td class="dim" style="font-size:12px"><%= run.rag_chunk_count %></td>
            <td class="dim" style="font-size:11px;white-space:nowrap"><%= run.created_at.strftime("%-d %b %H:%M") %></td>
            <td><a href="/ops/ai_runs/<%= run.id %>" style="font-size:11px">inspect</a></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  </div>
<% end %>

<%
  event_logs = EventLog.where(subject_type: "BookingRequest", subject_id: @booking_request.id)
                       .order(created_at: :asc)
%>
<% if event_logs.any? %>
  <div class="section-heading">Event log</div>
  <div class="card">
    <div class="table-scroll">
    <table class="data-table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Event</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody>
        <% event_logs.each do |log| %>
          <tr>
            <td class="dim" style="white-space:nowrap"><%= log.created_at.strftime("%-d %b %Y %H:%M") %></td>
            <td><code style="font-size:11px"><%= log.event_type %></code></td>
            <td class="dim" style="font-size:11px">
              <% log.payload.each do |k, v| %>
                <span style="color:var(--muted)"><%= k %>:</span> <span style="color:var(--text)"><%= v %></span>&nbsp;
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  </div>
<% end %>
