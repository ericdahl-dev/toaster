<div class="page-header">
  <div>
    <h1 class="page-title">Booking Requests</h1>
    <p class="page-subtitle"><%= @booking_requests.size %> <%= @show_archived ? "archived" : "active" %></p>
  </div>
  <div>
    <% if @show_archived %>
      <%= link_to "Show active", booking_requests_path, class: "btn btn-ghost" %>
    <% else %>
      <%= link_to "Show archived", booking_requests_path(show_archived: 1), class: "btn btn-ghost" %>
    <% end %>
  </div>
</div>

<% if @booking_requests.empty? %>
  <div class="card">
    <div class="empty-state">
      <div class="empty-icon">📋</div>
      <% if @show_archived %>
        <span>No archived booking requests</span>
      <% else %>
        <span>No booking requests yet</span>
        <span class="dim" style="font-size:11px">Requests appear here once mail sync runs</span>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="card">
    <div class="table-scroll">
    <table class="data-table booking-requests-table">
      <thead>
        <tr>
          <th class="booking-requests-col--contact">Contact</th>
          <th class="booking-requests-col--thread">Thread</th>
          <th class="booking-requests-col--date">Event date</th>
          <th class="booking-requests-col--secondary">Venue</th>
          <th class="booking-requests-col--secondary">Headcount</th>
          <th>Status</th>
          <th class="booking-requests-col--secondary">First received</th>
          <th class="booking-requests-col--secondary">Last activity</th>
          <th class="booking-requests-col--secondary booking-requests-col--action"></th>
        </tr>
      </thead>
      <tbody>
        <% @booking_requests.each do |br| %>
          <tr onclick="location.href='<%= booking_request_path(br) %>'">
            <td class="booking-requests-col--contact">
              <a href="<%= booking_request_path(br) %>">
                <span class="hi"><%= br.contact.name %></span>
                <% if @requests_per_contact[br.contact_id].to_i > 1 %>
                  <span class="dim" style="font-size:10px;margin-left:6px" title="This contact has multiple booking requests">
                    <%= @requests_per_contact[br.contact_id] %> requests
                  </span>
                <% end %>
                <br><span class="dim" style="font-size:11px"><%= br.contact.email %></span>
              </a>
            </td>
            <td class="booking-requests-col--thread">
              <% subject = br.conversation_thread.subject.presence || "(no subject)" %>
              <%= link_to subject, inbox_thread_path(br.conversation_thread),
                    class: "dim booking-request-thread-link",
                    onclick: "event.stopPropagation()" %>
            </td>
            <td class="booking-requests-col--date"><%= br.event_date&.strftime("%-d %b %Y") || "—" %></td>
            <td class="booking-requests-col--secondary"><%= br.venue&.name || "—" %></td>
            <td class="booking-requests-col--secondary"><%= br.headcount || "—" %></td>
            <td>
              <span class="badge badge-<%= br.status %>"><%= br.status %></span>
            </td>
            <td class="dim booking-requests-col--secondary" style="font-size:11px;white-space:nowrap">
              <%= br.first_received_at.strftime("%-d %b %Y") %>
            </td>
            <td class="dim booking-requests-col--secondary" style="font-size:11px;white-space:nowrap">
              <span title="<%= br.last_activity_direction_label %>"><%= br.last_activity_direction_label %></span>
              · <%= br.last_activity_at.strftime("%-d %b %Y %H:%M") %>
            </td>
            <td class="booking-requests-col--secondary booking-requests-col--action" onclick="event.stopPropagation()">
              <% if @show_archived %>
                <%= button_to "Restore",
                      unarchive_booking_request_path(br),
                      method: :post,
                      class: "btn btn-ghost",
                      style: "font-size:11px;padding:4px 8px" %>
              <% else %>
                <%
                  archive_confirm = if @pending_review_draft_ids.include?(br.id) || @open_task_ids.include?(br.id)
                    "Archive anyway? This request still has an open draft or review task."
                  else
                    "Archive this booking request? It will be hidden from the main list."
                  end
                %>
                <%= button_to "Archive",
                      archive_booking_request_path(br),
                      method: :post,
                      class: "btn btn-ghost",
                      style: "font-size:11px;padding:4px 8px",
                      data: { turbo_confirm: archive_confirm } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  </div>
<% end %>
