<div class="page-header">
  <div>
    <h1 class="page-title">Booking Requests</h1>
    <p class="page-subtitle"><%= @booking_requests.size %> total</p>
  </div>
</div>

<% if @booking_requests.empty? %>
  <div class="card">
    <div class="empty-state">
      <div class="empty-icon">📋</div>
      <span>No booking requests yet</span>
      <span class="dim" style="font-size:11px">Requests appear here once mail sync runs</span>
    </div>
  </div>
<% else %>
  <div class="card">
    <div class="table-scroll">
    <table class="data-table">
      <thead>
        <tr>
          <th>Contact</th>
          <th>Thread</th>
          <th>Event date</th>
          <th>Venue</th>
          <th>Headcount</th>
          <th>Status</th>
          <th>First received</th>
          <th>Last activity</th>
        </tr>
      </thead>
      <tbody>
        <% @booking_requests.each do |br| %>
          <tr onclick="location.href='<%= booking_request_path(br) %>'">
            <td>
              <a href="<%= booking_request_path(br) %>">
                <span class="hi"><%= br.contact.name %></span>
                <% if @requests_per_contact[br.contact_id].to_i > 1 %>
                  <span class="dim" style="font-size:10px;margin-left:6px" title="This contact has multiple booking requests">
                    <%= @requests_per_contact[br.contact_id] %> requests
                  </span>
                <% end %>
                <br><span class="dim" style="font-size:11px"><%= br.contact.email %></span>
              </a>
            </td>
            <td>
              <% subject = br.conversation_thread.subject.presence || "(no subject)" %>
              <%= link_to subject, inbox_thread_path(br.conversation_thread),
                    class: "dim",
                    style: "font-size:11px;display:block;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap",
                    onclick: "event.stopPropagation()" %>
            </td>
            <td><%= br.event_date&.strftime("%-d %b %Y") || "—" %></td>
            <td><%= br.venue&.name || "—" %></td>
            <td><%= br.headcount || "—" %></td>
            <td>
              <span class="badge badge-<%= br.status %>"><%= br.status %></span>
            </td>
            <td class="dim" style="font-size:11px;white-space:nowrap">
              <%= br.first_received_at.strftime("%-d %b %Y") %>
            </td>
            <td class="dim" style="font-size:11px;white-space:nowrap">
              <span title="<%= br.last_activity_direction_label %>"><%= br.last_activity_direction_label %></span>
              · <%= br.last_activity_at.strftime("%-d %b %Y %H:%M") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  </div>
<% end %>
