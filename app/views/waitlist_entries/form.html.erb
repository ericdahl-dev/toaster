<%= turbo_frame_tag "waitlist" do %>
  <%= form_with url: waitlist_path, model: @entry, html: {class: "lp-waitlist-form lp-waitlist-form--lg"} do |f| %>
    <div class="lp-waitlist-fields">
      <div class="lp-waitlist-row">
        <div class="lp-waitlist-field-block">
          <%= f.label :full_name, "Your name", class: "lp-waitlist-label" %>
          <%= f.text_field :full_name,
                class: "lp-waitlist-input lp-waitlist-input--lg #{"lp-waitlist-input--error" if @entry.errors[:full_name].any?}",
                autocomplete: "name" %>
        </div>
        <div class="lp-waitlist-field-block">
          <%= f.label :company_name, "Venue or company", class: "lp-waitlist-label" %>
          <%= f.text_field :company_name,
                class: "lp-waitlist-input lp-waitlist-input--lg #{"lp-waitlist-input--error" if @entry.errors[:company_name].any?}",
                autocomplete: "organization" %>
        </div>
      </div>
      <div class="lp-waitlist-field-block lp-waitlist-field-block--submit">
        <%= f.label :email, "Email", class: "lp-waitlist-label" %>
        <div class="lp-waitlist-field">
          <%= f.email_field :email,
                class: "lp-waitlist-input lp-waitlist-input--lg #{"lp-waitlist-input--error" if @entry.errors[:email].any?}",
                autocomplete: "email" %>
          <%= f.submit "Request access", class: "lp-waitlist-btn lp-waitlist-btn--lg" %>
        </div>
      </div>
      <% (@entry.errors[:full_name] + @entry.errors[:company_name] + @entry.errors[:email]).each do |msg| %>
        <p class="lp-waitlist-error"><%= msg %></p>
      <% end %>
    </div>
  <% end %>
<% end %>
