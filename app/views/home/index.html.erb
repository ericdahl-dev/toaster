<% content_for :title, "Toaster — Stop chasing booking inquiries" %>
<% content_for :head do %>
  <meta name="description" content="Venue operators use Toaster to turn a flood of booking emails into organized requests — with AI-drafted replies ready to approve. Invite-only beta.">
  <meta property="og:title" content="Toaster — Stop chasing booking inquiries">
  <meta property="og:description" content="Your inbox is full of booking requests. Toaster reads them, extracts the details, and drafts the reply. You just say yes.">
  <meta property="og:type" content="website">
<% end %>

<% content_for :fullpage do %>
<div class="lp">

  <%# ── Nav ── %>
  <header class="lp-nav">
    <a href="/" class="lp-nav-logo">
      <div class="lp-nav-icon">🍞</div>
      <span>Toaster</span>
    </a>
    <%= link_to "Sign in", login_path, class: "btn btn-ghost lp-nav-signin" %>
  </header>

  <%# ── Hero ── %>
  <section class="lp-hero">
    <div class="lp-hero-glow" aria-hidden="true"></div>
    <div class="lp-hero-inner">
      <p class="lp-eyebrow">Invite-only beta</p>
      <h1 class="lp-headline">
        Booking inquiries.<br>
        <span class="lp-headline-accent">Answered before<br>you open them.</span>
      </h1>
      <p class="lp-sub">
        Every inquiry that lands in your venue's inbox gets read, parsed, and
        replied to — automatically. You review the draft and hit send.
        No chasing, no copy-pasting, no missed leads.
      </p>
      <div class="lp-cta-row">
        <%= link_to "Sign in to my account", login_path, class: "btn btn-ghost lp-cta-btn" %>
      </div>
      <div class="lp-hero-waitlist">
        <%= turbo_frame_tag "waitlist" do %>
          <%= form_with url: waitlist_path, html: {class: "lp-waitlist-form"} do |f| %>
            <div class="lp-waitlist-field">
              <%= f.email_field :email,
                    name: "waitlist_entry[email]",
                    placeholder: "your@email.com",
                    class: "lp-waitlist-input",
                    autocomplete: "email",
                    aria: {label: "Email address"} %>
              <%= f.submit "Join waitlist", class: "lp-waitlist-btn" %>
            </div>
          <% end %>
        <% end %>
        <p class="lp-cta-note">Invite-only beta &mdash; no spam, ever.</p>
      </div>
    </div>
  </section>

  <%# ── Pain ── %>
  <section class="lp-pain">
    <div class="lp-pain-inner">
      <p class="lp-section-label">Sound familiar?</p>
      <div class="lp-pain-grid">
        <div class="lp-pain-item">
          <span class="lp-pain-mark">—</span>
          <p>Booking emails pile up while you're running the venue</p>
        </div>
        <div class="lp-pain-item">
          <span class="lp-pain-mark">—</span>
          <p>You copy event dates and headcounts into a spreadsheet by hand</p>
        </div>
        <div class="lp-pain-item">
          <span class="lp-pain-mark">—</span>
          <p>A lead goes cold because a reply slipped through the cracks</p>
        </div>
      </div>
    </div>
  </section>

  <%# ── How it works ── %>
  <section class="lp-steps">
    <p class="lp-section-label">How Toaster works</p>
    <div class="lp-steps-grid">
      <div class="lp-step">
        <div class="lp-step-num">01</div>
        <h3 class="lp-step-title">Connect your inbox</h3>
        <p class="lp-step-body">Link your venue's email in one step. Toaster watches for new inquiries around the clock — nothing slips past.</p>
      </div>
      <div class="lp-step">
        <div class="lp-step-num">02</div>
        <h3 class="lp-step-title">AI reads every inquiry</h3>
        <p class="lp-step-body">Date, headcount, budget, venue — extracted and filed automatically. Every request organized the moment it arrives.</p>
      </div>
      <div class="lp-step">
        <div class="lp-step-num">03</div>
        <h3 class="lp-step-title">You approve, it sends</h3>
        <p class="lp-step-body">Toaster drafts the reply in your voice. Edit if you want, or send as-is. You stay in control of every response.</p>
      </div>
    </div>
  </section>

  <%# ── Waitlist section ── %>
  <section class="lp-waitlist-section">
    <div class="lp-waitlist-section-inner">
      <div class="lp-waitlist-section-glow" aria-hidden="true"></div>
      <p class="lp-section-label">Early access</p>
      <h2 class="lp-waitlist-section-heading">
        Be first in the door.<br>
        <span class="lp-headline-accent">Your inbox can't wait.</span>
      </h2>
      <p class="lp-waitlist-section-sub">
        Toaster is invite-only while we work closely with early operators.
        Drop your email and we'll reach out when your spot opens up.
      </p>
      <%= turbo_frame_tag "waitlist-section" do %>
        <%= form_with url: waitlist_path, html: {class: "lp-waitlist-form lp-waitlist-form--lg"} do |f| %>
          <div class="lp-waitlist-field">
            <%= f.email_field :email,
                  name: "waitlist_entry[email]",
                  placeholder: "your@email.com",
                  class: "lp-waitlist-input lp-waitlist-input--lg",
                  autocomplete: "email",
                  aria: {label: "Email address"} %>
            <%= f.submit "Request access", class: "lp-waitlist-btn lp-waitlist-btn--lg" %>
          </div>
        <% end %>
      <% end %>
      <p class="lp-waitlist-section-note">No spam. No credit card. Just a heads-up when you're in.</p>
    </div>
  </section>

  <%# ── Footer ── %>
  <footer class="lp-footer">
    <div class="lp-footer-logo">
      <div class="lp-nav-icon lp-footer-icon">🍞</div>
      <span>Toaster</span>
    </div>
    <p class="lp-footer-copy">AI booking assistant for venue operators &mdash; invite-only beta</p>
  </footer>

</div>
<% end %>
