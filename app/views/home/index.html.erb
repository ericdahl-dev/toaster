<% content_for :title, "Toaster — AI booking assistant for venues" %>
<% content_for :head do %>
  <meta name="description" content="Toaster connects to your inbox, extracts booking requests with AI, and helps you respond faster. Built for venue operators and event spaces.">
  <meta property="og:title" content="Toaster — AI booking assistant for venues">
  <meta property="og:description" content="Connect your inbox. Let AI handle the first pass. You stay in control.">
  <meta property="og:type" content="website">
<% end %>

<% content_for :fullpage do %>
<div class="lp">

  <%# ── Nav ── %>
  <header class="lp-nav">
    <a href="/" class="lp-nav-logo">
      <div class="lp-nav-icon">🍞</div>
      <span>Toaster</span>
    </a>
    <%= link_to "Sign in", login_path, class: "btn btn-ghost lp-nav-signin" %>
  </header>

  <%# ── Hero ── %>
  <section class="lp-hero">
    <div class="lp-hero-glow" aria-hidden="true"></div>
    <div class="lp-hero-inner">
      <p class="lp-eyebrow">Invite-only beta</p>
      <h1 class="lp-headline">
        Your inbox handles<br>
        booking requests.<br>
        <span class="lp-headline-accent">Toaster handles the rest.</span>
      </h1>
      <p class="lp-sub">
        Connect your venue's email. Toaster reads every inquiry,
        extracts the details, and drafts a reply — you just approve.
      </p>
      <div class="lp-cta-row">
        <%= link_to "Sign in", login_path, class: "btn btn-amber lp-cta-btn" %>
        <span class="lp-cta-note">Currently invite-only</span>
      </div>
    </div>
  </section>

  <%# ── How it works ── %>
  <section class="lp-steps">
    <p class="lp-section-label">How it works</p>
    <div class="lp-steps-grid">
      <div class="lp-step">
        <div class="lp-step-num">01</div>
        <h3 class="lp-step-title">Connect your inbox</h3>
        <p class="lp-step-body">Link your venue's IMAP mailbox in one step. Toaster syncs new messages in the background.</p>
      </div>
      <div class="lp-step">
        <div class="lp-step-num">02</div>
        <h3 class="lp-step-title">AI extracts the details</h3>
        <p class="lp-step-body">Event date, headcount, venue, budget — pulled automatically from each inquiry and filed as a booking request.</p>
      </div>
      <div class="lp-step">
        <div class="lp-step-num">03</div>
        <h3 class="lp-step-title">Approve and send</h3>
        <p class="lp-step-body">Review the AI-drafted reply, make edits if needed, and send. Your words, AI speed.</p>
      </div>
    </div>
  </section>

  <%# ── Footer ── %>
  <footer class="lp-footer">
    <div class="lp-footer-logo">
      <div class="lp-nav-icon lp-footer-icon">🍞</div>
      <span>Toaster</span>
    </div>
    <p class="lp-footer-copy">AI booking assistant for venues &mdash; invite-only beta</p>
  </footer>

</div>
<% end %>
