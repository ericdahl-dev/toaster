# Copy to .env and fill in values for local development.
# DATABASE_URL is required for development (points to Neon or local Postgres).
# Omit DATABASE_URL entirely to use a local Unix socket (if running Postgres locally).
# In test, DATABASE_URL is never used — tests always hit local Postgres directly.
#
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
OPS_AUTH_TOKEN=dev-ops-token
APP_HOST=localhost:3000
RESEND_API_KEY=re_test_key
JOB_CONCURRENCY=1
PGGSSENCMODE=disable
