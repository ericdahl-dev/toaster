.DS_Store
.env
.env.*

# Rails runtime/build artifacts
backend/log/
backend/tmp/
backend/.bundle/
backend/vendor/bundle/
backend/config/master.key
# credentials.yml.enc is encrypted; safe to commit. RAILS_MASTER_KEY in deploy must decrypt it.

# Next.js runtime artifacts
frontend/.next/
frontend/node_modules/
frontend/.yarn/unplugged/
frontend/.yarn/install-state.gz
/backend/coverage
/frontend/coverage

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
